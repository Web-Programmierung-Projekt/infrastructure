# Template for secrets/dev.env. Copy to dev.env (gitignored) and fill in real
# values. On the VM, secrets/<env>.env is generated from GCP Secret Manager by
# bootstrap-vm.sh.

DATABASE_URL=postgresql+asyncpg://wohnmobil_dev_user:CHANGE_ME@127.0.0.1:5432/wohnmobil_dev
TEST_DATABASE_URL=postgresql+asyncpg://wohnmobil_dev_user:CHANGE_ME@127.0.0.1:5432/wohnmobil_dev_test

JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MIN=15
REFRESH_TOKEN_EXPIRE_DAYS=7

WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Wohnmobil-Buchungsplattform (dev)
WEBAUTHN_ORIGIN=http://localhost:3000

FRONTEND_URL=http://localhost:3000
