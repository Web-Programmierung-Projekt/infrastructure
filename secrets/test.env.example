DATABASE_URL=postgresql+asyncpg://wohnmobil_test_user:CHANGE_ME@127.0.0.1:5432/wohnmobil_test
TEST_DATABASE_URL=postgresql+asyncpg://wohnmobil_test_user:CHANGE_ME@127.0.0.1:5432/wohnmobil_test_ci

# Must be ≥32 chars and not a placeholder. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MIN=15
REFRESH_TOKEN_EXPIRE_DAYS=7

WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Wohnmobil-Buchungsplattform (test)
WEBAUTHN_ORIGIN=http://localhost:3001

FRONTEND_URL=http://localhost:3001

# Transactional email — appended by bootstrap-vm.sh from Secret Manager.
# Leave unset to log every email to stdout instead of sending via Resend.
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=Freiheit <onboarding@resend.dev>
